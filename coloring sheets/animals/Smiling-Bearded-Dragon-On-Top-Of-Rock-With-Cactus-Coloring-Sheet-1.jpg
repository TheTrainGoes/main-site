} */

.mm_favorite_header:hover .mm-favorite_count {
	color: #4fb9bd;
}

.mm_favorite_header.mm_wiggle_animate {
	animation-name: wiggle;
  animation-duration: .3s;
  animation-timing-function: ease-in-out;
	transform-origin: 50% 50%;
  animation-iteration-count: 1;
}

.sticky-header-content #primary-nav .nav-list li.menu-item.mm_favorite_header a {
    margin-top: 1px;
}

#primary-nav .nav-list li.menu-item.mm_favorite_header a {
    padding: 0;
    margin-left: 13px;
    margin-top: 0px;
    position: relative;
}

header.fixed-header button.search-toggle {
    margin-top: 5px;
}
