.mm_download_btn {
	  position: -webkit-sticky;
    position: sticky;
    z-index: 999;
    top: 55px;
    margin: auto;
    opacity: 0;
    visibility: hidden;
    transition: all ease 300ms;
    width: 100%;
    max-width: 728px;
    background: #fff;
    border-radius: 13px;
    height: 0;
}

.mm_download_btn .dpsp-pin-it-button {display: none !important}

.admin-bar .mm_download_btn {
	top: 90px;
}

.mm_download_btn.btn_active {
    opacity: 1;
    visibility: visible;
}
.mm_download_btn img {
    display: block;
    height: auto;
    border-radius: 14px;
    box-shadow: 0px 0px 10px rgba(0,0,0,0.2);
    transition: all ease 300ms;
	-webkit-animation: mday-shaking 20s infinite;
	-webkit-animation-delay: 20s;
	animation: mday-shaking 20s infinite;
	animation-delay: 20s;
}

.mm_download_btn a:hover img {
    -webkit-animation: mday-shake .82s cubic-bezier(.36,.07,.19,.97) both;
    animation: mday-shake .82s cubic-bezier(.36,.07,.19,.97) both;
}

.mm_download_btn a:hover img {
    -webkit-transform: translate3d(0,0,0);
    -moz-transform: translate3d(0,0,0);
    -ms-transform: translate3d(0,0,0);
    transform: translate3d(0,0,0);
    -webkit-backface-visibility: hidden;
    backface-visibility: hidden;
    perspective: 1000px;
	  filter: brightness(1.3);
}

/* .mm_download_btn a:hover img {
    opacity: 0.8;
		animation: mday-shake 0.82s cubic-bezier(.36,.07,.19,.97) both;
		transform: translate3d(0, 0, 0);
		backface-visibility: hidden;
		perspective: 1000px;
} */

.single p.trellis-comment-date {display: none;}

.single .trellis-comments .trellis-comment-text {
    margin-bottom: 0;
    align-self: center;
}

#content .article.excerpt .article-read-more {
    display: none
}

#content .article.excerpt .excerpt-excerpt > .article-read-more {
    display: inline-block;
}
.wp-block-column figure.wp-block-image.size-large.add-box-shadow {
    display: flex;
    flex-wrap: wrap;
}


@media all and (max-width: 1350px){
	.nav #primary-nav .nav-list .menu-item a {
		font-size: 15px
	}
	
	.nav .nav-list .menu-item a {
    padding-right: 10px;
    padding-left: 10px;
	}
}
@media all and (max-width: 1159px){
	.header.fixed-header .header-container {
		height: 50px;
	}
	.fixed-header .nav-toggle {
		padding-bottom: 0;
		padding-top: 0;
	}
	body.sticky-header-content {
		padding-top: 123px
	}
	li.menu-item.mm_favorite_header,.mm_favorite_wrap {
    display: none;
}
}

@media all and (max-width: 767px){
		div#bmc-wbtn, div#bmc-wbtn+div {display: none !important}
	.gutentor-module.gutentor-module-carousel span.slick-arrow > i:after {
    width: 50px;
}

.gutentor-module.gutentor-module-carousel span.slick-prev.slick-arrow {
    left: -30px !important;
}

.gutentor-module.gutentor-module-carousel span.slick-next.slick-arrow {
    right: -30px !important;
}
	.mm_favorite_wrap {
    display: none;
}

}
