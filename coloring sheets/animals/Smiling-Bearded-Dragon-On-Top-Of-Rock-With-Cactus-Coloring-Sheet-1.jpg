}

.gutentor-module.gutentor-module-carousel span.slick-prev > i:after {
    background: url(/wp-content/uploads/newback.png);
}
.gutentor-module.gutentor-module-carousel span.slick-arrow > i:before{display: none !important}
.gutentor-module.gutentor-module-carousel span.slick-arrow > i:after {
    content: "";
    width: 65px;
    height: 80px;
    display: block;
    background-size: contain;
    background-repeat:no-repeat;
    background-position: center
}

