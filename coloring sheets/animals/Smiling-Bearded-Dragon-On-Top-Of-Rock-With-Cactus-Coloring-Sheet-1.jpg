/*MV - Add Advertisement to Sidebar BTF*/
#sidebar_btf_sticky_wrapper::before {
    content: "ADVERTISEMENT";
    position: absolute;
    display: flex!important;
    align-items: center;
    justify-content: center;
    height: 20px;
    width: 100%;
    text-align: center;
    color: #a5a5a5;
    font-size: 11px;
    letter-spacing: 2px;
    top: 2px;    
}
#sidebar_btf_sticky_wrapper {
    padding-top: 30px !important;
}
/*MV - Add Advertisement to Sidebar BTF END*/
.universalPlayer_wrapper .mv-outstream-mute:after {
word-break: normal;
}
.adhesion_buttons mv-ad-reporter:before { 
content: "Ad"; 
position: absolute; 
top: -20px; 
left: 0px; 
color: lightgrey; 
font-size: 12px; 
width: fit-content; 
}
header button.search-toggle svg {
    width: 35px;
    height: 35px;
}

.wp-block-search button[type="submit"]:before {
    content: "";
    display: block;
    background-image: url(/wp-content/uploads/search.png);
    width: 100%;
    height: 30px;
    background-repeat: no-repeat;
    background-size: contain;
    background-position: center;
}

.wp-block-search button[type="submit"]:hover {
    transform: scale(1.2);
}

body .wp-block-search button[type="submit"] {
    font-size: 0 !important;
}

.wp-block-search button[type="submit"] {
    position: absolute;
    right: 0;
    bottom: 0;
    top: 0;
    margin: auto;
    margin-bottom: 12px;
    border: 0;
    background: transparent;
    width: 50px;
    transition: all ease 300ms;
}

.wp-block-search__inside-wrapper  {
    position: relative;
}
body .widget_block .wp-block-search button[type="submit"] {
    margin-bottom: 0;
}


.header-container #search-container button.search-submit {
    margin: 0;
    position: absolute;
    background: transparent;
    border: 0;
    padding: 0;
    min-width: initial;
    right: 0;
    box-shadow: none;
    height: 42px;
    width: 40px;
    line-height: 55px;
    transition: all ease 300ms;
}

.header-container #search-container form {
    position: relative;
}

.header-container #search-container button.search-submit svg {
    fill: #66c2c6;
}

.header-container #search-container button.search-submit:hover {
    transform: scale(1.2);
}

.wp-block-search__inside-wrapper input {
    padding-right: 50px;
}

.header-container #search-container form input.search-field {
    padding-right: 40px;
}
