    button.search-toggle {padding-left: 15px;}

.nav .nav-list .menu-item a {
    padding-right: 13px;
    padding-left: 13px;
}
/* .mm_favorite_header .mm-favorite_count {
    background: transparent;
    box-shadow: none;
