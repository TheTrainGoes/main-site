} */


.mm_favorite_header:hover .mm-favorite_count {
	color: inherit;
/* 	filter: brightness(0.55) */
}
.mm_favorite_header .mm-favorite_count {
    position: absolute;
    left: 0;
    right: 0;
    text-align: center;
    font-size: 18px;
    font-weight: 700;
    line-height: 54px;
	transition: all ease 300ms;
}

svg.star_icon {
    width: 54px;
    fill: #4fb9bd;
    transition: all ease 300ms;
    height: 48px;
}

li.menu-item.mm_favorite_header a:hover svg {
    fill: var(--mv-trellis-color-link-hover,#767676);
}

#primary-nav .nav-list li.menu-item.mm_favorite_header a {
    display: flex;
}

#primary-nav .nav-list li.menu-item.mm_favorite_header a {
    transform: scale(0.9);
    transition: none;
}
/* li.menu-item.mm_favorite_header {
    display: none;
} */
button.mm-delete-btn i {
    display: none;
}

button.mm-delete-btn:before {
    content: "\00d7";
    font-size: 27px;
    line-height: 16px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-family: 'Arial', sans-serif;
}

div#grow-me-root {
    display: none !important;
}
button#mm_favorite:before {
    content: "";
    background: url('https://mondaymandala.com/wp-content/plugins/mondaymandala-functions/assets/img/star_half.svg');
    width: 60px;
    height: 60px;
    background-size: contain;
    display: block;
    background-repeat: no-repeat;
    background-position: center;
    background-size: 30px;
}

button#mm_favorite:hover:before, .mm-side-btn[data-action="unfavorite"]:before {
    background-image: url('https://mondaymandala.com/wp-content/plugins/mondaymandala-functions/assets/img/star_full.svg') !important;
    background-repeat: no-repeat;
}


.mm_favorite_wrap {
  position: relative; 
}

.mm_favorite_wrap .tooltiptext {
    visibility: hidden;
    width: 120px;
    border: 1px solid #000;
	background-color: white;
    color: #000;
    text-align: center;
    padding: 5px 0;
    border-radius: 6px;
    position: absolute;
    z-index: 1;
    top: -8px;
    font-size: 13px;
    bottom: 0;
    height: 31px;
    margin: auto;
    left: 73px;
	opacity: 0;
	transition: all ease 300ms
}

#mm_favorite:hover+.tooltiptext {
  visibility: visible;
	opacity: 1;
}

#mm_favorite.mm-side-btn[data-action="unfavorite"]:hover +.tooltiptext {
	opacity: 0;
}
.mm_favorite_header .mm-favorite_count:not(:hover) {
    color: #4fb9bd !important;
}

#primary-nav a:not(:hover), .menu-item a:active {
    color: #4fb9bd !important;
}
.mm_favorite_icon {
    display: none;
}

li.menu-item.mm_favorite_header {
    display: none;
}
div#bmc-wbtn {
    top: 0px;
    bottom: 0;
    margin: auto 0;
}

div#bmc-wbtn+div {
    height: 87px;
    top: -20px;
    bottom: 0 !important;
    margin: auto 0 !important;
}
