.flurry-container {
    margin-left: -100% !important;
}

.mm-side-btn:hover {
    background: #146885;
    cursor: pointer;
    box-shadow: 0 0 15px rgba(0, 0, 0, 0.5);
    transform: scale(1.1);
}
.mm-side-btn[data-action="unfavorite"] i, .mm-side-btn.mm-loading i {
    font-weight: 900;
}
.article-meta.mondaymandala_meta .post-author img.blue-check {
    max-width: 18px;
    margin-left: 3px;
    margin-right: 2px;
}
.mm-side-btn[data-action="unfavorite"]{
    background: #146885;
}

.mm-side-btn.mm-loading {
	pointer-events: none;
}

.mm-side-btn.mm-loading:before {
    content: "";
    width: 28px;
    height: 28px;
    border: 3px solid #FFF;
    border-bottom-color: transparent;
    border-radius: 50%;
    display: inline-block;
    box-sizing: border-box;
    animation: rotation 1s linear infinite;
    margin-top: 4px;
}

.mm-side-btn.mm-loading i {
    display: none;
}

.mm-side-btn[data-action="unfavorite"] {
	animation: pop 0.4s linear 1;
}
.mm-side-btn:hover i {
    font-weight: 900
}

body.adhesion .mm_favorite_icon {
    bottom: 110px;
}

.mm_favorite_icon {
    position: fixed;
    z-index: 99;
    bottom: 20px;
    left: 20px;
    transition: all ease 400ms;
}

.mm-side-btn {
    background: #4fb9bd;
    border: 0;
    color: #fff;
    width: 60px;
    height: 60px;
    font-size: 25px;
    border-radius: 50%;
    transition: all ease 300ms;
    box-shadow: 0 0 10px rgba(0, 0, 0, 0.3);
    cursor: pointer;
}

.mm_saved_wrap {
    display: flex;
    flex-wrap: wrap;
    margin: 30px -10px 0;
}

.mm_saved_wrap .mm_saved_post {
    width: calc(50% - 20px);
    margin: 0 10px 15px;
}

.mm_saved_wrap .mm_saved_post a {
    text-decoration: none;
    text-align: center;
}

.mm_saved_wrap .mm_saved_post a h4 {
    font-size: 20px;
    color: #4fb9bd;
    margin-top: 5px;
    transition: all ease 300ms;
}

.mm_saved_wrap .mm_saved_post a:hover h4 {
    color: #146885;
}

.mm_saved_post img {
    height: 200px;
    object-fit: contain;
    display: block;
    border-radius: 10px;
	width: 100%
}

.mm_saved_post span.mm_no_image {
    height: 200px;
    display: block;
    border-radius: 10px;
    background: #f5e8df;
}
.mm_pagination {
    text-align: center;
}

.mm_pagination a {
    color: #146885 !important;
    background-color: #ffffff !important;
    text-decoration: none !important;
    border: 1px solid #cccccc !important;
    margin-bottom: 0.5rem;
    display: inline-block;
    padding: 0.3rem 0.5rem;
}

.mm_pagination a:first-child {
    margin-right: 10px;
}

.mm_pagination a:last-child {
    margin-left: 15px;
}

.mm_pagination a:hover {
    color: #000 !important;
}

.mm_pagination > span {
    font-size: 20px;
}
.mm-delete-btn {
    background: #4fb9bd;
    border: 0;
    color: #fff;
    width: 30px;
    height: 30px;
    border-radius: 50%;
    position: absolute;
    top: -11px;
    right: -11px;
    font-size: 14px;
    cursor: pointer;
    transition: all ease 300ms;
    line-height: 31px;
}

.mm_saved_post {
    position: relative;
	  transition: all ease 300ms
}

.mm-delete-btn:hover {
    background: #146885;
}

.mm_saved_post.mm-deleting {
    opacity: 0.3;
    pointer-events: none;
}

.mm_favorite_header i {
    font-size: 48px;
    -webkit-text-stroke: 0.8px #fff;
	transition: all ease 300ms;
}
.nav .menu-item.mm_favorite_header a {
    padding-left: 0;
    padding-top: 7px;
}

